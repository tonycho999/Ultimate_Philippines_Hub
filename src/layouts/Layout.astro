---
import { getCollection } from 'astro:content';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

// 모든 블로그 글에서 'category'를 중복 없이 가져오기
const posts = await getCollection('blog');
const categories = [...new Set(posts.map((post) => post.data.category))];
---
<!doctype html>
<html lang="en">
	<head>
		{/* head 부분은 이전과 동일하게 유지 */}
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Ultimate Philippines Hub</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-gray-50 text-gray-900 font-inter">
		<header class="bg-blue-600 text-white p-4 shadow-md sticky top-0 z-50">
			<nav class="max-w-5xl mx-auto flex justify-between items-center">
				<a href="/" class="text-2xl font-bold">Ultimate PH Hub</a>
				<ul class="flex space-x-6 text-lg items-center">
					<li><a href="/" class="hover:underline">Home</a></li>
					{/* 동적으로 생성된 카테고리 메뉴 */}
					{categories.map((category) => (
						<li>
							<a href={`/category/${category.toLowerCase()}`} class="hover:underline capitalize">
								{category}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</header>
		
		<main class="max-w-5xl mx-auto p-4 my-8">
			<slot />
		</main>

		<footer class="bg-gray-800 text-white text-center p-6 mt-12">
			<p>&copy; {new Date().getFullYear()} Ultimate Philippines Hub. All rights reserved.</p>
		</footer>
	</body>
</html>
<style is:global>
	body { font-family: 'Inter', sans-serif; }
</style>
