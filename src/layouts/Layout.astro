---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		{/* head 부분은 그대로 유지 */}
        {/* ... */}
	</head>
	<body class="bg-gray-50 text-gray-900 font-inter">
		<header class="bg-blue-600 text-white p-4 shadow-md sticky top-0 z-50">
			<nav class="max-w-5xl mx-auto flex justify-between items-center">
				<a href="/" class="text-2xl font-bold">Ultimate PH Hub</a>
				<ul class="flex space-x-6 text-lg items-center">
					<li><a href="/" class="hover:underline">Home</a></li>
					{/* 'Blog' 페이지로 가는 링크 추가 */}
					<li><a href="/blog" class="hover:underline">Blog</a></li>
				</ul>
			</nav>
		</header>
		
		<main class="max-w-5xl mx-auto p-4 my-8">
			<slot />
		</main>

		<footer class="bg-gray-800 text-white text-center p-6 mt-12">
			<p>&copy; {new Date().getFullYear()} Ultimate Philippines Hub. All rights reserved.</p>
		</footer>
	</body>
</html>
<style is:global>
	body { font-family: 'Inter', sans-serif; }
</style>
