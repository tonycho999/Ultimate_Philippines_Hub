---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 'blog' 컬렉션의 모든 마크다운 파일을 가져와서 날짜순으로 정렬
const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Welcome" description="Your ultimate guide to travel, golf, and lifestyle in the Philippines.">
	<section class="mb-12 text-center">
		<h1 class="text-4xl font-extrabold mb-4">Discover the Philippines</h1>
		<p class="text-lg text-gray-600">Explore travel guides, golf courses, culture, and lifestyle tips.</p>
	</section>

	<section class="grid grid-cols-1 md:grid-cols-2 gap-8">
		{posts.map((post) => (
			<article class="bg-white rounded-lg shadow overflow-hidden transition-transform hover:-translate-y-1">
				{post.data.image && (
					<img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
				)}
				<div class="p-6">
					<span class="text-sm font-semibold text-blue-600 uppercase tracking-wide">{post.data.category}</span>
					<h2 class="text-2xl font-bold mt-2 mb-3">
						<a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
							{post.data.title}
						</a>
					</h2>
					<p class="text-gray-600 mb-4">{post.data.description}</p>
					<div class="text-sm text-gray-500">
						{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
					</div>
				</div>
			</article>
		))}
	</section>
</Layout>
